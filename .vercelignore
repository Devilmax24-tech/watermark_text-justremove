# Python environment - excluded from Vercel
venv/
env/
.venv/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd

# Git and config
.git/
.gitignore
.gitattributes
.env*
*.local

# OS and IDE
.DS_Store
.vscode/
.idea/
*.log

# Documentation (keep lightweight)
*.md
LICENSE

# Model files (too large - load on-demand if possible)
algorithms/models/*.pt
algorithms/models/*.onnx
algorithms/models/*.pth

# Build artifacts
dist/
build/
.pytest_cache/
.coverage

# Large data files
data/
output/
downloads/

# Docker (not needed for Vercel)
Dockerfile
.dockerignore

# Other deployment (use either Vercel OR Render)
render.yaml

# Testing
.pytest_cache/
.coverage
htmlcov/
